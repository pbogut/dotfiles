{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "chat",
  "agent": {
    "build": {
      "disable": true
    },
    "plan": {
      "disable": true
    },
    "chat": {
      "mode": "primary",
      "model": "opencode-go/deepseek-v4-pro",
      "variant": "medium",
      "description": "General chat agent with web access only",
      "permission": {
        "bash": "ask",
        "edit": "ask",
        "write": "ask",
        "read": "ask",
        "glob": "ask",
        "grep": "ask",
        "webfetch": "allow",
        "websearch": "allow"
      },
      "prompt": "You are a helpful general-purpose chat assistant. You have access to the web to fetch information. Do not attempt to modify files or execute shell commands."
    }
  },
  "provider": {{ include (joinPath .chezmoi.homeDir ".config/opencode/providers.json") }}
}
