add_newline = false
# right_format = "$time"
format = """
$time$status$cmd_duration$all${custom.lf}${custom.yazi}$shell
$username$hostname${custom.local_host}${custom.remote_host}$directory$git_branch$git_status$git_state
$character\
"""

[cmd_duration]
format = '\[¾░£Ä [$duration]($style)\] '

[status]
format = '[$symbol$status]($style) '
disabled = false

[line_break]
disabled = true

[character]
error_symbol = '[╬╗](bold red)'
success_symbol = '[╬╗](bold red)'

[hostname]
disabled = false
ssh_only = false
format= '[$ssh_symbol]($style)[\]](bold red) '
ssh_symbol = '[@](bold red)[$hostname](bold yellow)'
style = 'bold yellow'

[username]
show_always = true
format= '[\[](bold red)[$user]($style)'
style_user = 'gray'

[time]
disabled = false
format = '[\[$time\]]($style) '
time_format = '%T'
utc_time_offset = 'local'
style = 'green'

[shell]
format = '[$indicator]($style) '
style = 'white'
zsh_indicator = '' # default one
disabled = false

[directory]
format = '[\(](bold red)[$path]($style)[\)](bold red)[$read_only]($read_only_style) '
truncate_to_repo = false
truncation_symbol = "ÔÇĞ/"

[directory.substitutions]
#{{ range $full, $short := .dir_aliases }}
'{{ $full }}' = '{{ $short }}'
#{{ end }}
'{{ .projects }}' = '~p'

[git_status]
disabled = true

[git_state]
disabled = true

[git_branch]
format = '[$symbol$branch(:$remote_branch)]($style) '
style = 'blue'

[custom.local_host]
disabled = true
format = '[$output]($style)[\]](bold red) '
# command = 'hostname'
style = 'gray'
when = 'test -z "$SSH_TTY"'

[custom.remote_host]
disabled = true
format = '[$output]($style)[\]](bold red) '
command = 'hostname'
style = 'bold yellow'
when = 'test -n "$SSH_TTY"'

[custom.yazi]
symbol = 'ya'
format = '[$symbol\[$output\]]($style) '
command = 'echo $YAZI_LEVEL'
style = 'bold purple'
when = "[[ -n $YAZI_LEVEL ]]"

[custom.lf]
symbol = 'lf'
format = '[$symbol\[$output\]]($style) '
command = 'echo $LF_LEVEL'
style = 'bold blue'
when = "[[ -n $LF_LEVEL ]]"

[custom.elixir]
symbol = '¯İ¡ '
format = '[$symbol(v$output )]($style)'
command = "elixir --short-version 2>/dev/null || (elixir --version | grep '^Elixir' | awk '{print $2}')"
when = "test -f mix.exs"
style = 'bold purple'

[custom.godot]
symbol = '¯Öş '
format = '[$symbol(v$output )]($style)'
command = 'godot --version | sed -E "s/(^[0-9\.]+[0-9]).*/\1/"'
when = "test -f project.godot"
style = 'bold blue'
# symbol = '¯ëÁ '

[custom.docker]
disabled = false
# symbol = '­şÉ│ '
symbol = '¾░í¿ '

style = 'bold blue'
command = '(docker-compose ls | awk "{print $3}" | grep "$(realpath $PWD)/docker-compose.yml" >/dev/null) && echo "up" || echo "down"'
when = "test -f docker-compose.yml"

